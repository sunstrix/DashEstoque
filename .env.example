# ============================================================================
# DashEstoque - Arquivo de Configuracao de Variaveis de Ambiente
# ============================================================================
#
# INSTRUCOES:
# 1. Copie este arquivo e renomeie para ".env" (sem o .example)
# 2. Preencha as URLs das suas planilhas nos campos abaixo
# 3. NUNCA commite o arquivo .env no Git (ele ja esta no .gitignore)
# 4. Este arquivo (.env.example) PODE ser versionado como referencia
#
# ============================================================================

# ============================================================================
# PORTA DO SERVIDOR (Opcional - padrao: 3000)
# ============================================================================
PORT=3000

# ============================================================================
# URLs DAS PLANILHAS
# ============================================================================
#
# O sistema suporta 2 formatos de URL:
#
# FORMATO 1 - SharePoint (recomendado):
#   https://suaempresa.sharepoint.com/:x:/s/NomeDoSite/TOKEN?e=XXXXX
#   (Compartilhe a planilha como "Qualquer pessoa com o link pode visualizar")
#
# FORMATO 2 - Google Sheets:
#   https://docs.google.com/spreadsheets/d/ID_DA_PLANILHA/export?format=xlsx
#   (A planilha deve estar compartilhada como "Qualquer pessoa com o link")
#
# ============================================================================

# --------------------------------------------------------------------------
# [OBRIGATORIA] Planilha Principal
# --------------------------------------------------------------------------
# Conteudo: estoque, preco tabela, classe/curva, categoria por SKU
# Abas esperadas: BOTICARIO, EUDORA, QUEM_DISSE_BERENICE
# Colunas esperadas: EAN/Codigo, QTD/Estoque, Preco Tabela, Curva/Classe,
#                    Categoria/Grupo, Produto/Nome
#
# Se esta URL nao estiver configurada, o servidor NAO iniciara.
#
# Exemplo SharePoint:
SPREADSHEET_MAIN_URL=https://didiernsf.sharepoint.com/:x:/s/NSFcosmticosepresentesLTDA/IQA-Wz0yzpnqSYa2YVVRybyWAUAs0EmwaQUPi4LDTGuAduU?e=E9TbRs
#
# Exemplo Google Sheets (alternativo):
# SPREADSHEET_MAIN_URL=https://docs.google.com/spreadsheets/d/1EDDyKie9UiugMLMowcPzHfViqzziFcSgxVPvZ2Rx3L0/export?format=xlsx

# --------------------------------------------------------------------------
# [OPCIONAL] Planilha Draft de Custos
# --------------------------------------------------------------------------
# Conteudo: mapeamento de lojas para os 17 PDVs + custo unitario por SKU
# Aba esperada: primeira aba da planilha
# Colunas esperadas: Loja, EAN/Codigo/SKU, Custo
#
# Se esta URL nao estiver configurada:
#   - O custo draft sera 0 para todos os itens
#   - O custo final sera apenas o preco de tabela
#   - O dashboard funciona normalmente, mas sem a comparacao de custos
#
# Exemplo SharePoint:
SPREADSHEET_DRAFT_URL=https://didiernsf.sharepoint.com/:x:/s/NSFcosmticosepresentesLTDA/IQCujrbIbWZLT50lUu7tb2V7Aew2WFZQK1Uo2c4T583mDnU?e=5RIBrD
#
# Exemplo Google Sheets (alternativo):
# SPREADSHEET_DRAFT_URL=https://docs.google.com/spreadsheets/d/11Z21gFvJ9pm2xSlF3IweC7xcYZwAZWrjcWDnRe5LexY/export?format=xlsx

# --------------------------------------------------------------------------
# [OPCIONAL] Planilha de Estoque de Seguranca
# --------------------------------------------------------------------------
# Conteudo: estoque minimo/seguranca por SKU, separado por marca
# Abas esperadas: BOT, EUD, QDB
# Colunas esperadas: EAN/Codigo/SKU, Estoque de Seguranca/Minimo
#
# Se esta URL nao estiver configurada:
#   - O estoque de seguranca sera 0 para todos os itens
#   - Nao havera calculo de excesso/falta
#   - Os KPIs de Valor Falta e Valor Excesso serao 0
#   - O dashboard funciona normalmente, mas sem analise de ruptura
#
# Exemplo SharePoint:
SPREADSHEET_SAFETY_STOCK_URL=https://didiernsf.sharepoint.com/:x:/s/NSFcosmticosepresentesLTDA/IQBrGlued5zuSbFM3MWSTXUrAZWfbWg18JffEkgyzhBgcYw?e=McCxBr
#
# Exemplo Google Sheets (alternativo):
# SPREADSHEET_SAFETY_STOCK_URL=https://docs.google.com/spreadsheets/d/1uHonFnFM4p7bz4s7YpewhKHNs6fSEfw9rDMTKC7jtHE/export?format=xlsx

# --------------------------------------------------------------------------
# [OPCIONAL] Planilha de Itens Ignorados
# --------------------------------------------------------------------------
# Conteudo: lista de SKUs que devem ser excluidos das analises
#           (geralmente sacolas, brindes e produtos sem relevancia)
# Aba esperada: primeira aba da planilha
# Colunas esperadas: EAN/Codigo/SKU (qualquer coluna com este nome sera usada)
#
# Se esta URL nao estiver configurada:
#   - Nenhum item sera filtrado/excluido
#   - Sacolas e itens irrelevantes aparecerao nos calculos
#   - O dashboard funciona normalmente, mas com dados potencialmente inflados
#
# Exemplo SharePoint:
SPREADSHEET_IGNORED_URL=https://didiernsf.sharepoint.com/:x:/s/NSFcosmticosepresentesLTDA/IQASGB3GLaJRS71jgs_72MP8AYI2PEbGup2KMRWfhdSIOfs?e=G3I27o

# ============================================================================
# TABELA DE REFERENCIA RAPIDA
# ============================================================================
#
# | Variavel                    | Status      | Se Faltar                              |
# |-----------------------------|-------------|----------------------------------------|
# | PORT                        | Opcional    | Usa porta 3000                         |
# | SPREADSHEET_MAIN_URL        | OBRIGATORIA | Servidor NAO inicia                    |
# | SPREADSHEET_DRAFT_URL       | Opcional    | Custo draft = 0 (usa preco de tabela)  |
# | SPREADSHEET_SAFETY_STOCK_URL| Opcional    | Estoque seguranca = 0 (sem exc/falta)  |
# | SPREADSHEET_IGNORED_URL     | Opcional    | Sem filtro (sacolas aparecem)          |
#
# ============================================================================
#
# PDVs MONITORADOS (17 lojas):
#
# | Codigo | Loja                 |
# |--------|----------------------|
# | 4842   | Metropole            |
# | 5152   | Coracao              |
# | 6105   | Assai Anchieta       |
# | 6106   | Direita              |
# | 6110   | Arouche              |
# | 8001   | Dom Jose             |
# | 11576  | Davo                 |
# | 12055  | Sao Bento            |
# | 12056  | Marechal             |
# | 12605  | Coop                 |
# | 12645  | Light                |
# | 14120  | VD SBC               |
# | 14353  | VD SP                |
# | 20371  | Luz                  |
# | 21502  | Bem Barato           |
# | 23000  | Outlet               |
# | 23379  | Assai Piraporinha    |
#
# ============================================================================
#
# MARCAS MONITORADAS:
# - O Boticario (aba BOTICARIO / BOT)
# - Eudora (aba EUDORA / EUD)
# - Quem Disse, Berenice? (aba QUEM_DISSE_BERENICE / QDB)
#
# ============================================================================
#
# REGRA DE CUSTO:
# - Se so tem preco de tabela -> usa preco de tabela
# - Se so tem custo draft -> usa custo draft
# - Se tem ambos -> usa o MAIOR valor
# - Se nao tem nenhum -> custo = 0
#
# ============================================================================